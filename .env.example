# Public deployment configuration only. This static site reads its browser-safe
# Supabase publishable key from js/config.js.
PUBLIC_SITE_URL=https://toucan-music.com
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR-PUBLISHABLE-KEY

# Never add Supabase secret/service-role keys to this file or js/config.js.
# Configure server-side credentials with `supabase secrets set` instead.
